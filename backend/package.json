{
  "name": "citizen-minister-engagement-portal-backend",
  "version": "1.0.0",
  "description": "Secure backend for the Citizen-Minister Engagement Portal",
  "main": "server.js",
  "scripts": {
    "dev": "NODE_ENV=development node server.js",
    "start": "NODE_ENV=production node server.js",
    "migrate": "node db/postgres/seeds/seed.js migrate",
    "seed": "node db/postgres/seeds/seed.js seed",
    "generate:admin-token": "node scripts/generateAdminRegistrationToken.js",
    "test": "jest --runInBand",
    "lint:security": "npm audit --audit-level=high"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.56.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "file-type": "^19.6.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "ioredis": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.0",
    "pg": "^8.14.1",
    "sanitize-html": "^2.15.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ]
  }
}
