NODE_ENV=production
PORT=3000
FRONTEND_ORIGINS=https://portal.example.gov.in,http://localhost:5173
DATABASE_URL=postgresql://app_user:password@postgres:5432/citizen_portal
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DB_PASSWORD=
REDIS_URL=redis://:password@redis:6379
REDIS_PASSWORD=
REDIS_METRICS_TTL_SECONDS=300
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_CITIZEN_PRIVATE_KEY=
JWT_CITIZEN_PUBLIC_KEY=
JWT_MASTERADMIN_PRIVATE_KEY=
JWT_MASTERADMIN_PUBLIC_KEY=
JWT_ADMIN_PRIVATE_KEY=
JWT_ADMIN_PUBLIC_KEY=
JWT_DEO_PRIVATE_KEY=
JWT_DEO_PUBLIC_KEY=
JWT_MINISTER_PRIVATE_KEY=
JWT_MINISTER_PUBLIC_KEY=
JWT_ISSUER=citizen-portal
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
AADHAAR_ENC_KEY=
RECAPTCHA_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
SMS_PROVIDER=mock
ALERT_EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SESSION_SECRET=
UPLOAD_DIR=./uploads
PRIVATE_FILE_BASE_URL=https://portal.example.gov.in
CLAMAV_ENABLED=false
ADMIN_MANUAL_UNLOCK_EMAIL=security@example.gov.in
STORAGE_MODE=aws
S3_BUCKET=portal-private-files
S3_SIGNED_URL_EXPIRY_SECONDS=90

# AWS production configuration. Leave keys empty on EC2 when using an IAM role.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MinIO / local S3-compatible configuration
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
