# Production template. Copy this file to .env on the EC2 host and fill every PASTE_* value.
NODE_ENV=production
PORT=3000
HTTP_PORT=80
RUN_MIGRATIONS=true

# Public origin for the current no-domain EC2 deployment.
# Example: FRONTEND_ORIGINS=http://13.201.10.20
FRONTEND_ORIGINS=http://PASTE_EC2_PUBLIC_IP
VITE_API_BASE_URL=/api/v1
COOKIE_SECURE=false

# Local single-EC2 database and Redis. Use long random values.
DB_PASSWORD=PASTE_LONG_RANDOM_POSTGRES_PASSWORD
REDIS_PASSWORD=PASTE_LONG_RANDOM_REDIS_PASSWORD
DATABASE_URL=postgresql://app_user:PASTE_LONG_RANDOM_POSTGRES_PASSWORD@postgres:5432/citizen_portal
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
REDIS_URL=redis://:PASTE_LONG_RANDOM_REDIS_PASSWORD@redis:6379

# Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Then store each PEM as a single line with literal \n line breaks.
JWT_ISSUER=citizen-portal
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
JWT_PRIVATE_KEY=PASTE_PROD_RSA_PRIVATE_KEY_WITH_LITERAL_N
JWT_PUBLIC_KEY=PASTE_PROD_RSA_PUBLIC_KEY_WITH_LITERAL_N

# 64 hex chars. Generate with: openssl rand -hex 32
AADHAAR_ENC_KEY=PASTE_64_HEX_CHARS

# Optional external providers.
RECAPTCHA_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMS_PROVIDER=mock
ALERT_EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_MANUAL_UNLOCK_EMAIL=

# Production file storage: private AWS S3 bucket.
# Prefer an EC2 IAM role later. For this temporary setup, access keys can be set here on the EC2 .env only.
STORAGE_MODE=aws
S3_BUCKET=PASTE_PRIVATE_S3_BUCKET_NAME
S3_SIGNED_URL_EXPIRY_SECONDS=90
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=PASTE_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=PASTE_AWS_SECRET_ACCESS_KEY
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=
S3_FORCE_PATH_STYLE=false
PRIVATE_FILE_BASE_URL=

# Operational tuning.
REDIS_METRICS_TTL_SECONDS=300
CLAMAV_ENABLED=false
AUTH_STREAM_BATCH_SIZE=25
AUTH_STREAM_BLOCK_MS=5000
AUTH_STREAM_POLL_INTERVAL_MS=250
AUTH_STREAM_CONCURRENCY=5
AUTH_STREAM_MAX_RETRIES=5
AUTH_STREAM_CLAIM_IDLE_MS=60000
AUTH_STREAM_REPLAY_BATCH_SIZE=100
IDLE_TIMEOUT_SECONDS=1800
MAX_SESSION_SECONDS=28800
POOL_MAX_PER_WORKER=5
WS_HEARTBEAT_INTERVAL_MS=30000
